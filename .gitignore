# Exception: the specific Australia 2026 files required by `make build` in CI.
# (Don't commit heavy telemetry like CarData.z / Position.z; only the small
# metadata + tyre + timing files the precompute pipeline reads.)
!/seasons/2026/
/seasons/2026/*
!/seasons/2026/2026-03-08_Australian_Grand_Prix/
/seasons/2026/2026-03-08_Australian_Grand_Prix/*
!/seasons/2026/2026-03-08_Australian_Grand_Prix/*/
/seasons/2026/2026-03-08_Australian_Grand_Prix/*/*
!/seasons/2026/2026-03-08_Australian_Grand_Prix/*/SessionInfo.json
!/seasons/2026/2026-03-08_Australian_Grand_Prix/*/DriverList.jsonStream
!/seasons/2026/2026-03-08_Australian_Grand_Prix/*/TyreStintSeries.jsonStream
!/seasons/2026/2026-03-08_Australian_Grand_Prix/*/TimingAppData.jsonStream

